<Window x:Class="OwTranslateLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OW Translator Lite" Height="720" Width="1060"
        MinHeight="640" MinWidth="920"
        Background="#101214" Foreground="#F4F7F5"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F7F5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#07100C"/>
            <Setter Property="Background" Value="#78D995"/>
            <Setter Property="BorderBrush" Value="#78D995"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#F4F7F5"/>
            <Setter Property="BorderBrush" Value="#3B454C"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#F4F7F5"/>
            <Setter Property="BorderBrush" Value="#3B454C"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#101214"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F7F5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="OW Translator Lite" FontSize="28" FontWeight="Bold"/>
                <TextBlock x:Name="SubtitleText" Text="简体中文实时竞技翻译" Foreground="#9FB0A8" Margin="1,4,0,0"/>
            </StackPanel>
            <Border DockPanel.Dock="Right" Padding="10,6" Background="#1B2024" BorderBrush="#3B454C" BorderThickness="1">
                <TextBlock x:Name="GlossaryStatusText" Text="Glossary" Foreground="#B8F3C7"/>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
            <StackPanel>
                <Border x:Name="FirstRunPanel" Background="#18211B" BorderBrush="#78D995" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="首次配置" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="选择 OCR、翻译方式和聊天区域后即可开始。" Foreground="#AFC6B6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <Button Content="完成首次配置" Margin="0,12,0,0" Click="FinishFirstRun_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="OCR" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="引擎" Foreground="#AFC6B6" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="识别模式" Foreground="#AFC6B6" FontSize="12"/>
                    <ComboBox x:Name="OcrEngineCombo" Grid.Row="1" Grid.Column="0" IsEnabled="False" SelectionChanged="OcrSettings_SelectionChanged">
                        <ComboBoxItem Content="OneOCR"/>
                    </ComboBox>
                    <ComboBox x:Name="OcrLanguageCombo" Grid.Row="1" Grid.Column="2" IsEnabled="False" SelectionChanged="OcrSettings_SelectionChanged">
                        <ComboBoxItem Content="自动" Tag="auto"/>
                    </ComboBox>
                </Grid>
                <TextBlock Text="当前固定使用 OneOCR 自动识别；输出固定为简体中文。当前 OneOCR 本地接口不支持强制指定 EN/JA/KO。" Foreground="#8FA19A" TextWrapping="Wrap" Margin="0,-8,0,14"/>

                <TextBlock Text="翻译" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="ProviderCombo" SelectionChanged="ProviderCombo_SelectionChanged" Margin="0,0,0,10">
                    <ComboBoxItem Content="DeepSeek"/>
                    <ComboBoxItem Content="OpenAI Compatible"/>
                </ComboBox>

                <TextBlock Text="API URL" Foreground="#AFC6B6"/>
                <TextBox x:Name="ApiUrlBox" Margin="0,4,0,10" TextChanged="TranslationSettings_Changed"/>
                <TextBlock Text="API Key" Foreground="#AFC6B6"/>
                <PasswordBox x:Name="ApiKeyBox" Margin="0,4,0,10" PasswordChanged="TranslationSettings_Changed"/>
                <TextBlock Text="Model" Foreground="#AFC6B6"/>
                <Grid Margin="0,4,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ModelCombo" IsEditable="True" SelectionChanged="TranslationSettings_Changed"/>
                    <Button x:Name="FetchModelsButton" Grid.Column="2" Content="获取模型" Click="FetchModels_Click"/>
                </Grid>

                <TextBlock Text="翻译框" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="字号" Foreground="#AFC6B6"/>
                        <Slider x:Name="FontSizeSlider" Minimum="14" Maximum="32" Value="20" ValueChanged="OverlaySettings_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="透明度" Foreground="#AFC6B6"/>
                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="1" Value="0.86" ValueChanged="OverlaySettings_Changed"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="ClickThroughCheck" Content="鼠标穿透" Margin="0,0,0,6" Checked="OverlaySettings_Changed" Unchecked="OverlaySettings_Changed"/>
                <CheckBox x:Name="ReplyInputBarCheck" Content="显示回话输入条" Margin="0,0,0,6" Checked="OverlaySettings_Changed" Unchecked="OverlaySettings_Changed"/>
                <TextBlock Text="默认开启鼠标穿透，不挡游戏操作；回话输入条可点击输入，关闭后仍可用热键临时唤起。" Foreground="#8FA19A" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ReplyHotkeyCheck"
                              Content="启用回话热键"
                              VerticalAlignment="Center"
                              Checked="ReplyHotkeySettings_Changed"
                              Unchecked="ReplyHotkeySettings_Changed"/>
                    <ComboBox x:Name="ReplyHotkeyCombo"
                              Grid.Column="2"
                              SelectionChanged="ReplyHotkeySettings_Changed">
                        <ComboBoxItem Content="Ctrl+Shift+Enter"/>
                        <ComboBoxItem Content="Ctrl+Shift+Space"/>
                        <ComboBoxItem Content="Ctrl+Alt+Enter"/>
                        <ComboBoxItem Content="Alt+Shift+Enter"/>
                    </ComboBox>
                </Grid>
                <TextBlock x:Name="FrameAdjustHint"
                           Text="正在调整翻译框：拖动顶部横条移动，拖动右下角缩放。调整完成后请点击“完成调整”，程序会恢复鼠标穿透。"
                           Foreground="#EBCB6B"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,16"/>

                <WrapPanel>
                    <Button Content="选择聊天区域" Click="SelectArea_Click"/>
                    <Button Content="显示翻译框" Click="ShowOverlay_Click"/>
                    <Button x:Name="AdjustFrameButton" Content="调整翻译框" Background="#9BB7F0" BorderBrush="#9BB7F0" Click="AdjustFrame_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <Button x:Name="StartButton" Content="开始" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="暂停" Background="#EBCB6B" BorderBrush="#EBCB6B" Click="Stop_Click"/>
                </WrapPanel>

                <Border Background="#161A1E" BorderBrush="#2F3940" BorderThickness="1" Padding="12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Beta 测试" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button Content="打开数据目录" Margin="0,0,8,8" Click="OpenDataDirectory_Click"/>
                            <Button Content="打开日志" Margin="0,0,8,8" Click="OpenRuntimeLog_Click"/>
                            <Button Content="打开去重日志" Margin="0,0,8,8" Click="OpenDedupeLog_Click"/>
                            <Button Content="导出诊断" Margin="0,0,8,8" Click="ExportDiagnostics_Click"/>
                            <Button Content="清除本机数据" Margin="0,0,8,8" Background="#F29F9F" BorderBrush="#F29F9F" Click="ClearUserData_Click"/>
                        </WrapPanel>
                        <CheckBox x:Name="DedupeDebugCheck"
                                  Content="记录去重调试日志"
                                  Margin="0,2,0,6"
                                  Checked="BetaDebugSettings_Changed"
                                  Unchecked="BetaDebugSettings_Changed"/>
                        <TextBlock Text="测试版用于排查问题；导出的诊断会脱敏 API Key。去重调试日志默认关闭，测试重复问题时再开启。" Foreground="#8FA19A" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#161A1E" BorderBrush="#2F3940" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="RegionText" Text="未选择区域" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatusText" Text="待机" Foreground="#9FB0A8" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="LatencyText" Grid.Column="1" Text="0 ms" FontSize="24" FontWeight="Bold" Foreground="#78D995" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#0B0D0F" BorderBrush="#2F3940" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="14,12">
                            <TextBlock Text="实时记录" FontWeight="SemiBold"/>
                            <Button DockPanel.Dock="Right" Content="清空" Width="68" Height="30" Click="ClearLog_Click"/>
                        </DockPanel>
                        <ListBox x:Name="LogList" Grid.Row="1" Background="#0B0D0F" BorderThickness="0" Foreground="#F4F7F5" Padding="12"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="配置保存在用户 AppData，本项目本地 Git 管理，默认不联网推送。" Foreground="#8FA19A" Margin="0,14,0,0"/>
    </Grid>
</Window>
