<Window x:Class="OwTranslateLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OW Translator Lite" Height="720" Width="1060"
        MinHeight="640" MinWidth="920"
        Background="#101214" Foreground="#F4F7F5"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F7F5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#07100C"/>
            <Setter Property="Background" Value="#78D995"/>
            <Setter Property="BorderBrush" Value="#78D995"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#F4F7F5"/>
            <Setter Property="BorderBrush" Value="#3B454C"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#F4F7F5"/>
            <Setter Property="BorderBrush" Value="#3B454C"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#1B2024"/>
            <Setter Property="Foreground" Value="#101214"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F7F5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="OW Translator Lite" FontSize="28" FontWeight="Bold"/>
                <TextBlock x:Name="SubtitleText" Text="简体中文实时竞技翻译" Foreground="#9FB0A8" Margin="1,4,0,0"/>
            </StackPanel>
            <Border DockPanel.Dock="Right" Padding="10,6" Background="#1B2024" BorderBrush="#3B454C" BorderThickness="1">
                <TextBlock x:Name="GlossaryStatusText" Text="Glossary" Foreground="#B8F3C7"/>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
            <StackPanel>
                <Border x:Name="FirstRunPanel" Background="#18211B" BorderBrush="#78D995" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="首次配置" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="选择 OCR、翻译方式和聊天区域后即可开始。" Foreground="#AFC6B6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <Button Content="完成首次配置" Margin="0,12,0,0" Click="FinishFirstRun_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="OCR" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="引擎" Foreground="#AFC6B6" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="源语言识别" Foreground="#AFC6B6" FontSize="12"/>
                    <ComboBox x:Name="OcrEngineCombo" Grid.Row="1" Grid.Column="0">
                        <ComboBoxItem Content="OneOCR"/>
                        <ComboBoxItem Content="Windows OCR"/>
                    </ComboBox>
                    <ComboBox x:Name="OcrLanguageCombo" Grid.Row="1" Grid.Column="2">
                        <ComboBoxItem Content="auto"/>
                        <ComboBoxItem Content="en"/>
                        <ComboBoxItem Content="ja"/>
                        <ComboBoxItem Content="ko"/>
                        <ComboBoxItem Content="ru"/>
                        <ComboBoxItem Content="zh"/>
                    </ComboBox>
                </Grid>
                <TextBlock Text="输出固定为简体中文；这里选择的是 OCR 源语言，不是目标语言。" Foreground="#8FA19A" TextWrapping="Wrap" Margin="0,-8,0,14"/>

                <TextBlock Text="翻译" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="ProviderCombo" SelectionChanged="ProviderCombo_SelectionChanged" Margin="0,0,0,10">
                    <ComboBoxItem Content="Local"/>
                    <ComboBoxItem Content="DeepSeek"/>
                    <ComboBoxItem Content="OpenAI Compatible"/>
                </ComboBox>

                <TextBlock Text="API URL" Foreground="#AFC6B6"/>
                <TextBox x:Name="ApiUrlBox" Margin="0,4,0,10"/>
                <TextBlock Text="API Key" Foreground="#AFC6B6"/>
                <PasswordBox x:Name="ApiKeyBox" Margin="0,4,0,10"/>
                <TextBlock Text="Model" Foreground="#AFC6B6"/>
                <TextBox x:Name="ModelBox" Margin="0,4,0,14"/>

                <TextBlock Text="Overlay" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="显示模式" Foreground="#AFC6B6"/>
                <ComboBox x:Name="OverlayModeCombo" Margin="0,4,0,10">
                    <ComboBoxItem Content="Floating"/>
                    <ComboBoxItem Content="Inline"/>
                </ComboBox>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="字号" Foreground="#AFC6B6"/>
                        <Slider x:Name="FontSizeSlider" Minimum="14" Maximum="32" Value="20"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="透明度" Foreground="#AFC6B6"/>
                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="1" Value="0.86"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="ClickThroughCheck" Content="鼠标穿透" Margin="0,0,0,6"/>
                <TextBlock Text="Floating：关闭鼠标穿透后可拖动黑框；Inline：贴在原文行附近。" Foreground="#8FA19A" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <WrapPanel>
                    <Button Content="选择聊天区域" Click="SelectArea_Click"/>
                    <Button Content="显示 Overlay" Click="ShowOverlay_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <Button x:Name="StartButton" Content="开始" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="暂停" Background="#EBCB6B" BorderBrush="#EBCB6B" Click="Stop_Click"/>
                    <Button Content="保存设置" Background="#9BB7F0" BorderBrush="#9BB7F0" Click="SaveSettings_Click"/>
                </WrapPanel>
            </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#161A1E" BorderBrush="#2F3940" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="RegionText" Text="未选择区域" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatusText" Text="待机" Foreground="#9FB0A8" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="LatencyText" Grid.Column="1" Text="0 ms" FontSize="24" FontWeight="Bold" Foreground="#78D995" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#0B0D0F" BorderBrush="#2F3940" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="14,12">
                            <TextBlock Text="实时记录" FontWeight="SemiBold"/>
                            <Button DockPanel.Dock="Right" Content="清空" Width="68" Height="30" Click="ClearLog_Click"/>
                        </DockPanel>
                        <ListBox x:Name="LogList" Grid.Row="1" Background="#0B0D0F" BorderThickness="0" Foreground="#F4F7F5" Padding="12"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="配置保存在用户 AppData，本项目本地 Git 管理，默认不联网推送。" Foreground="#8FA19A" Margin="0,14,0,0"/>
    </Grid>
</Window>
