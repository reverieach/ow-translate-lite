<Window x:Class="OwTranslateLite.QuickStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Start" Height="680" Width="760"
        MinHeight="560" MinWidth="680"
        Background="#101214" Foreground="#F4F7F5"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F7F5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="#07100C"/>
            <Setter Property="Background" Value="#78D995"/>
            <Setter Property="BorderBrush" Value="#78D995"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F7F5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="OW Translator Lite Quick Start" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="建议按下面顺序完成配置。测试版 API Key 会保存在本机配置文件中，请不要把自己的 settings.json 一起分发。" Foreground="#AFC6B6" Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#151A1D" BorderBrush="#334047" BorderThickness="1" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="1. 设置 Overwatch" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="在 OW 的视频设置里把显示模式改成无边框窗口或窗口化无边框。不要使用独占全屏，否则截图和 overlay 可能不稳定。"/>
                    <TextBlock Text="确认聊天框正常显示，测试时可以先进入训练场或自定义房间。"/>

                    <TextBlock Text="2. 配置 DeepSeek API" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,6"/>
                    <TextBlock Text="打开 DeepSeek 开放平台，登录后进入 API Keys 页面创建密钥："/>
                    <TextBlock Text="https://platform.deepseek.com/api_keys" Foreground="#B8F3C7"/>
                    <TextBlock Text="在本程序里选择 DeepSeek，API URL 填 https://api.deepseek.com，把 API Key 粘贴到 API Key 输入框。"/>
                    <TextBlock Text="点击“获取模型”，从模型列表里选择 deepseek-v4-flash；如果无法获取模型，可先手动保留默认模型名。"/>

                    <TextBlock Text="3. 选择 OCR 源语言" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,6"/>
                    <TextBlock Text="当前固定使用 OneOCR。源语言不是目标语言，输出始终是简体中文。韩服/韩语聊天优先选择“韩语”，英语选择“英语”，日语选择“日语”。混合语言再尝试“自动”。"/>

                    <TextBlock Text="4. 框选聊天区域" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,6"/>
                    <TextBlock Text="点击“选择聊天区域”，框选 OW 左边的消息文本框部分即可。需要完整包含玩家消息文本，尤其是 [玩家名]：正文 这一整行。"/>
                    <TextBlock Text="区域不要框太大，尽量避开头像、技能 HUD、菜单提示和背景噪声；但也不要截断聊天行的顶部、底部或右侧文字。"/>

                    <TextBlock Text="5. 设置翻译框" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,6"/>
                    <TextBlock Text="点击“显示翻译框”可以预览位置。需要移动或缩放时点击“调整翻译框”，拖动顶部横条移动，拖动右下角调整大小；调整完成后点击“完成调整”，程序会恢复鼠标穿透。"/>
                    <TextBlock Text="透明度只影响黑色背景，不会让字体变糊。翻译框会保留最近 50 条翻译，OCR 没文字后会延迟隐藏但不清空历史。"/>

                    <TextBlock Text="6. 开始测试" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,6"/>
                    <TextBlock Text="所有配置都会自动保存并立即应用，确认 API、模型、OCR 源语言、聊天区域和翻译框位置后，点击“开始”。暂停会停止识别并隐藏翻译框，但不会清空历史；只有“清空”按钮会清空主日志和翻译框历史。"/>
                    <TextBlock Text="如果出现重复，优先检查是否框选过大；如果漏字，稍微扩大聊天框选区域。当前 OneOCR 自动识别，不支持强制指定源语言。"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <CheckBox x:Name="DoNotShowAgainCheck" Content="下次不再提示" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="开始配置" Width="110" Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
