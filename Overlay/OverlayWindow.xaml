<Window x:Class="OwTranslateLite.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Width="520" Height="180">
    <Border x:Name="FloatingPanel" BorderBrush="#5578D995" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="DragHandleRow" Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragHandle" Cursor="SizeAll" Background="#18000000" Margin="-4,-4,-4,8">
                <Border Width="72" Height="3" CornerRadius="2"
                        Background="#6678D995"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer x:Name="TranslationScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="RecordList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{Binding Speaker}" Foreground="#78D995" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TranslatedText}" Foreground="#F4F7F5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SourceText}" Foreground="#91A099" FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <primitives:Thumb x:Name="ResizeGrip"
                              Grid.RowSpan="3"
                              Width="22"
                              Height="22"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNWSE">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Border Width="14"
                                    Height="14"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    BorderBrush="#6678D995"
                                    BorderThickness="0,0,2,2"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>

            <Border x:Name="ReplyInputPanel"
                    Grid.Row="2"
                    Visibility="Visible"
                    Margin="0,10,0,0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ReplyTargetCombo"
                              Grid.Column="0"
                              BorderThickness="0"
                              Background="#1B2024"
                              Foreground="#101214"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="自动" Tag="auto"/>
                        <ComboBoxItem Content="英语" Tag="en"/>
                        <ComboBoxItem Content="日语" Tag="ja"/>
                        <ComboBoxItem Content="韩语" Tag="ko"/>
                    </ComboBox>
                    <TextBox x:Name="ReplyInputBox"
                             Grid.Column="2"
                             BorderThickness="0"
                             Background="#AA07090A"
                             Foreground="#F4F7F5"
                             CaretBrush="#78D995"
                             Padding="8,4"
                             VerticalContentAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
